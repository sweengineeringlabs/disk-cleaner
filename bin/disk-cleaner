#!/bin/bash

# disk-cleaner - Multi-language project workspace tool
#
# Commands:
#   clean           Remove build artifacts from detected projects (default)
#   search          Find and report projects without modifying them
#   list-profiles   Show available language profiles
#   help            Show usage information

# Resolve project root (parent of bin/)
PROJECT_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

# Source shared libraries
source "$PROJECT_ROOT/main/src/lib/common.sh"
source "$PROJECT_ROOT/main/src/lib/toml-parser.sh"

# Source features
source "$PROJECT_ROOT/main/features/clean/clean.sh"
source "$PROJECT_ROOT/main/features/search/search.sh"

# Defaults
COMMAND=""
DRY_RUN=false
PARALLEL=false
ALL=false
JSON_OUTPUT=false
SEARCH_PATH=""
LIST_PROFILES=false
declare -a EXCLUDE_PATTERNS=()
declare -a INCLUDE_PATTERNS=()
declare -a LANG_PROFILES=()

# Grand totals (modified by features)
grand_total_projects=0
grand_total_cleaned=0
grand_total_skipped=0
grand_total_size_bytes=0

# ─── Help ────────────────────────────────────────────────────────────────────────

show_help() {
    cat << 'EOF'
disk-cleaner - Multi-language project workspace tool

USAGE:
    disk-cleaner <command> [OPTIONS]

COMMANDS:
    clean             Remove build artifacts from detected projects (default)
    search            Find and report projects without modifying them
    list-profiles     Show available language profiles
    help              Show this help message

OPTIONS (shared):
    -l, --lang PROFILE      Language profile to target (repeatable, or "all")
    -c, --config FILE       Path to TOML config (default: main/config/profiles.toml)
    -L, --list-profiles     Show available profiles and exit
    -e, --exclude PATTERN   Exclude projects matching pattern (can be repeated)
    -i, --include PATTERN   Only include projects matching pattern (can be repeated)
    -p, --path PATH         Root path to search (defaults to config default or current dir)
    -a, --all               Process all projects, ignoring Exclude/Include filters
    -j, --json              Emit structured JSON lines instead of colored text
    -h, --help              Show this help message

OPTIONS (clean only):
    -d, --dry-run           Show what would be cleaned without cleaning
    -P, --parallel          Run clean operations in parallel

Press Ctrl+C at any time to cancel. A partial summary is printed on exit.

EXAMPLES:
    disk-cleaner clean --lang rust
    disk-cleaner clean --lang rust --lang node -d
    disk-cleaner search --lang all -p /path/to/projects
    disk-cleaner search --lang rust --json
    disk-cleaner --lang rust                              # clean is default
    disk-cleaner list-profiles

EOF
    exit 0
}

# ─── Resolve Config Path ────────────────────────────────────────────────────────

resolve_config() {
    if [[ -z "$CONFIG_FILE" ]]; then
        CONFIG_FILE="$PROJECT_ROOT/main/config/profiles.toml"
        # Fallback to legacy location
        if [[ ! -f "$CONFIG_FILE" ]]; then
            CONFIG_FILE="$PROJECT_ROOT/disk-cleaner.toml"
        fi
    fi
}

# ─── Argument Parsing ────────────────────────────────────────────────────────────

# First arg may be a command
if [[ $# -gt 0 ]]; then
    case "$1" in
        clean|search|list-profiles|help)
            COMMAND="$1"
            shift
            ;;
    esac
fi

while [[ $# -gt 0 ]]; do
    case $1 in
        -l|--lang)
            LANG_PROFILES+=("$2")
            shift 2
            ;;
        -c|--config)
            CONFIG_FILE="$2"
            shift 2
            ;;
        -L|--list-profiles)
            LIST_PROFILES=true
            shift
            ;;
        -e|--exclude)
            EXCLUDE_PATTERNS+=("$2")
            shift 2
            ;;
        -i|--include)
            INCLUDE_PATTERNS+=("$2")
            shift 2
            ;;
        -d|--dry-run)
            DRY_RUN=true
            shift
            ;;
        -p|--path)
            SEARCH_PATH="$2"
            shift 2
            ;;
        -P|--parallel)
            PARALLEL=true
            shift
            ;;
        -a|--all)
            ALL=true
            shift
            ;;
        -j|--json)
            JSON_OUTPUT=true
            shift
            ;;
        -h|--help)
            show_help
            ;;
        *)
            echo -e "${RED}Unknown option: $1${NC}"
            echo "Use -h or --help for usage information"
            exit 1
            ;;
    esac
done

# Handle -L shortcut
if [[ "$LIST_PROFILES" == true ]]; then
    COMMAND="list-profiles"
fi

# Default command
if [[ -z "$COMMAND" ]]; then
    COMMAND="clean"
fi

if [[ "$COMMAND" == "help" ]]; then
    show_help
fi

# ─── Load Config ─────────────────────────────────────────────────────────────────

resolve_config
parse_toml "$CONFIG_FILE"

# ─── List Profiles ───────────────────────────────────────────────────────────────

if [[ "$COMMAND" == "list-profiles" ]]; then
    echo -e "${CYAN}Available profiles (from $CONFIG_FILE):${NC}"
    echo ""
    for profile in "${TOML_PROFILES[@]}"; do
        local_name=$(toml_get "profiles.${profile}.name")
        local_marker=$(toml_get "profiles.${profile}.marker")
        local_type=$(toml_get "profiles.${profile}.type")
        echo -e "  ${WHITE}${profile}${NC} - ${local_name}"
        echo -e "    ${GRAY}marker: ${local_marker}  |  type: ${local_type}${NC}"
    done
    echo ""
    exit 0
fi

# ─── Resolve Profiles ───────────────────────────────────────────────────────────

if [[ ${#LANG_PROFILES[@]} -eq 0 ]]; then
    toml_get_array "settings.default_profiles" LANG_PROFILES
fi

declare -a RESOLVED_PROFILES=()
for lp in "${LANG_PROFILES[@]}"; do
    if [[ "$lp" == "all" ]]; then
        RESOLVED_PROFILES=("${TOML_PROFILES[@]}")
        break
    else
        if [[ -z "$(toml_get "profiles.${lp}.name")" ]]; then
            echo -e "${RED}Unknown profile: $lp${NC}"
            echo "Use list-profiles or --list-profiles to see available profiles"
            exit 1
        fi
        RESOLVED_PROFILES+=("$lp")
    fi
done
LANG_PROFILES=("${RESOLVED_PROFILES[@]}")

if [[ ${#LANG_PROFILES[@]} -eq 0 ]]; then
    echo -e "${RED}No profiles selected. Use --lang or set default_profiles in config.${NC}"
    exit 1
fi

# ─── Resolve Search Path ────────────────────────────────────────────────────────

if [[ -z "$SEARCH_PATH" ]]; then
    local_default_path=$(toml_get "settings.default_path")
    if [[ -n "$local_default_path" ]]; then
        SEARCH_PATH="$local_default_path"
    else
        SEARCH_PATH="$(pwd)"
    fi
fi

# ─── Cancel Trap ─────────────────────────────────────────────────────────────────

trap cancel_cleanup SIGINT

# ─── Dispatch Command ───────────────────────────────────────────────────────────

profile_idx=0
profile_count=${#LANG_PROFILES[@]}

case "$COMMAND" in
    clean)
        if [[ "$JSON_OUTPUT" == true ]]; then
            emit_json_event "{\"event\":\"start\",\"command\":\"clean\",\"config\":\"$CONFIG_FILE\",\"profiles\":[$(printf '\"%s\",' "${LANG_PROFILES[@]}" | sed 's/,$//')],\"path\":\"$SEARCH_PATH\",\"dry_run\":$DRY_RUN,\"parallel\":$PARALLEL}"
        else
            echo -e "${CYAN}disk-cleaner clean - Build artifact cleaner${NC}"
            echo -e "${GRAY}Config: $CONFIG_FILE${NC}"
            echo -e "${GRAY}Profiles: ${LANG_PROFILES[*]}${NC}"
        fi

        for profile in "${LANG_PROFILES[@]}"; do
            [[ "$CANCELLED" == true ]] && break
            profile_idx=$((profile_idx + 1))
            clean_profile "$profile" "$profile_idx" "$profile_count"
        done

        # Summary
        if [[ "$JSON_OUTPUT" == true ]]; then
            local_freed_fmt=$(format_size "$grand_total_size_bytes")
            emit_json_event "{\"event\":\"summary\",\"command\":\"clean\",\"profiles_run\":${#LANG_PROFILES[@]},\"projects_found\":$grand_total_projects,\"projects_cleaned\":$grand_total_cleaned,\"projects_skipped\":$grand_total_skipped,\"total_freed_bytes\":$grand_total_size_bytes,\"total_freed_formatted\":\"$local_freed_fmt\"}"
        else
            echo ""
            echo -e "${CYAN}==================================================${NC}"
            echo -e "${GREEN}Cleaning complete!${NC}"
            echo -e "${WHITE}  Profiles run:       ${#LANG_PROFILES[@]} (${LANG_PROFILES[*]})${NC}"
            echo -e "${WHITE}  Projects found:     $grand_total_projects${NC}"
            echo -e "${WHITE}  Projects cleaned:   $grand_total_cleaned${NC}"
            echo -e "${WHITE}  Projects skipped:   $grand_total_skipped${NC}"
            echo -e "${GREEN}  Total space freed:  $(format_size "$grand_total_size_bytes")${NC}"
        fi
        ;;

    search)
        if [[ "$JSON_OUTPUT" == true ]]; then
            emit_json_event "{\"event\":\"start\",\"command\":\"search\",\"config\":\"$CONFIG_FILE\",\"profiles\":[$(printf '\"%s\",' "${LANG_PROFILES[@]}" | sed 's/,$//')],\"path\":\"$SEARCH_PATH\"}"
        else
            echo -e "${CYAN}disk-cleaner search - Project finder${NC}"
            echo -e "${GRAY}Config: $CONFIG_FILE${NC}"
            echo -e "${GRAY}Profiles: ${LANG_PROFILES[*]}${NC}"
        fi

        for profile in "${LANG_PROFILES[@]}"; do
            [[ "$CANCELLED" == true ]] && break
            profile_idx=$((profile_idx + 1))
            search_profile "$profile" "$profile_idx" "$profile_count"
        done

        # Summary
        if [[ "$JSON_OUTPUT" == true ]]; then
            local_size_fmt=$(format_size "$grand_total_size_bytes")
            emit_json_event "{\"event\":\"summary\",\"command\":\"search\",\"profiles_run\":${#LANG_PROFILES[@]},\"projects_found\":$grand_total_projects,\"projects_matched\":$grand_total_cleaned,\"projects_skipped\":$grand_total_skipped,\"total_artifact_bytes\":$grand_total_size_bytes,\"total_artifact_formatted\":\"$local_size_fmt\"}"
        else
            echo ""
            echo -e "${CYAN}==================================================${NC}"
            echo -e "${GREEN}Search complete!${NC}"
            echo -e "${WHITE}  Profiles searched:  ${#LANG_PROFILES[@]} (${LANG_PROFILES[*]})${NC}"
            echo -e "${WHITE}  Projects found:     $grand_total_projects${NC}"
            echo -e "${WHITE}  Projects matched:   $grand_total_cleaned${NC}"
            echo -e "${WHITE}  Projects skipped:   $grand_total_skipped${NC}"
            echo -e "${YELLOW}  Total artifact size: $(format_size "$grand_total_size_bytes")${NC}"
        fi
        ;;
esac
